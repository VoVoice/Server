# VoVoice Server Environment Variables
# Copy this file to .env and fill in your values

# Required
OPENROUTER_TOKEN=sk-or-v1-your_token_here

# Security (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=your_random_secret_here

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_API_KEY=

# Domain (for Cloudflare deployment)
DOMAIN=

# Email (for account verification via Gmail SMTP)
# 1. Enable 2FA on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an app password for "Mail"
# 4. Use that 16-character password below (not your regular Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM=VoVoice <your_email@gmail.com>

# STT/TTS
STT_MODEL=base
STT_DEVICE=cpu
TTS_VOICE=en_US-lessac-medium

# Logging
LOG_LEVEL=INFO
