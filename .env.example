# VoVoice Server Environment Variables
# Copy this file to .env and fill in your values

# Required
OPENROUTER_TOKEN=sk-or-v1-your_token_here

# Security (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=your_random_secret_here

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_API_KEY=

# Domain (for Cloudflare deployment)
DOMAIN=

# Email (for account verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# STT/TTS
STT_MODEL=base
STT_DEVICE=cpu
TTS_VOICE=en_US-lessac-medium

# Logging
LOG_LEVEL=INFO
